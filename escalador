<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      /* Esto hace que el visor ocupe el 100% de la altura y ancho del dispositivo */
      model-viewer {
        width: 100%;
        height: 90vh; /* 90% de la altura de la pantalla */
        background-color: #f0f0f0;
      }
      body {
        margin: 0;
        padding: 0;
        overflow: hidden; /* Evita barras de desplazamiento innecesarias */
      }
    </style>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.0.0/model-viewer.min.js"></script>
  </head>
  <body>

    <model-viewer 
      src="Untitled1.glb" 
      ar 
      ar-modes="webxr scene-viewer quick-look" 
      camera-controls 
      tone-mapping="neutral" 
      poster-color="#fff"
      shadow-intensity="1">
    </model-viewer>

  </body>
</html>
